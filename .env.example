# Copy to .env for local development. Do not commit populated secrets.

# Model provider. "ollama" for local development; "openai-compatible" for
# hosted endpoints that implement the OpenAI chat completions API shape.
# VIKRAM_MODEL_PROVIDER=ollama

# Model identifier. Provider-dependent:
#   ollama            -> an Ollama tag, e.g. qwen3
#   openai-compatible -> a hosted model id, e.g. gpt-4.1-mini
VIKRAM_MODEL=qwen3

# Ollama local development.
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI-compatible hosted provider.
# Required when VIKRAM_MODEL_PROVIDER=openai-compatible.
# VIKRAM_OPENAI_COMPAT_API_KEY=
# VIKRAM_OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1

# Agent selection and local state.
# VIKRAM_AGENT=vikram
# VIKRAM_SPEC_ROOT=/abs/path/to/spec
# VIKRAM_DB_PATH=.vikram/vikram.sqlite3
# DBOS_SYSTEM_DATABASE_URL=sqlite:///.vikram/dbos.sqlite3
# VIKRAM_PUBLIC_BASE_URL=https://example.ngrok-free.app

# Logging and tracing.
# VIKRAM_LOG_LEVEL=INFO
# VIKRAM_OBSERVABILITY_ENABLED=false
# VIKRAM_OBSERVABILITY_SERVICE_NAME=vikram
# VIKRAM_OTLP_ENDPOINT=http://localhost:4318
# VIKRAM_OBSERVABILITY_CAPTURE_MESSAGE_CONTENT=false
# VIKRAM_OBSERVABILITY_DISABLE_METRICS=false
# VIKRAM_OBSERVABILITY_DISABLED_INSTRUMENTORS=mistral
# VIKRAM_CONTEXT_WINDOW_TOKENS=256000
# VIKRAM_CONTEXT_WARNING_RATIO=0.85

# Web search tool. Required if an active agent spec lists "web_search".
# PARALLEL_API_KEY=

# Telegram interface. These env names are referenced by spec/telegram.toml.
# VIKRAM_TELEGRAM_BOT_TOKEN=
# VIKRAM_TELEGRAM_WEBHOOK_SECRET=
# VIKRAM_TELEGRAM_ALLOWED_CHAT_IDS=123456789,-1001234567890
# VIKRAM_TELEGRAM_BOT_USERNAME=VikramBot
# VIKRAM_TELEGRAM_API_BASE_URL=https://api.telegram.org
